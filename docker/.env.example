# ===========================================
# HomeHub Docker 环境变量配置
# 复制此文件为 .env 并修改下方配置
# ===========================================

# ---- 服务端口 ----
CLIENT_PORT=80
SERVER_PORT=3000
DB_PORT=5432
REDIS_PORT=6379

# ---- 数据库 ----
DB_TYPE=postgres
DATABASE_URL=postgres://homehub:homehub-dev@homehub-db:5432/homehub
DB_PASSWORD=homehub-dev

# ---- 认证 (生产环境必须修改!) ----
JWT_SECRET=change-this-in-production
JWT_REFRESH_SECRET=change-this-refresh-in-production

# ---- CORS ----
CORS_ORIGIN=http://localhost
